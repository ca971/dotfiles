# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux ────────────────────────────────────────────────────────────────────
*~
.fuse_hidden*
.nfs*
.Trash-*

# ── Editors ──────────────────────────────────────────────────────────────────
# Vim / Neovim
*.swp
*.swo
*.swn
*~
.netrwhist
tags
Session.vim

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# JetBrains
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# ── ZSH ──────────────────────────────────────────────────────────────────────
*.zwc
*.zwc.old
.zcompdump*
.zsh_sessions/

# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt

# ── Build / Dependencies ────────────────────────────────────────────────────
node_modules/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
target/
dist/
build/
*.egg-info/
.tox/
.nox/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej
.direnv/
