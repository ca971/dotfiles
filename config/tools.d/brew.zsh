# ============================================================================
# Homebrew — aliases (only what we actually use)
# ============================================================================

alias brewup="brew update && brew upgrade && brew cleanup --prune=7"
alias brewi="brew install"
alias brews="brew search"
alias brewinfo="brew info"
alias brewls="brew list"
alias brewdeps="brew deps --tree --installed"
alias brewout="brew outdated"
alias brewdr="brew doctor"
alias brewsvc="brew services list"


