alias nx="nix"
alias nxs="nix search nixpkgs"
alias nxi="nix profile install"
alias nxr="nix profile remove"
alias nxl="nix profile list"
alias nxu="nix profile upgrade '.*'"
alias nxgc="nix-collect-garbage -d"
alias nxsh="nix-shell"
alias nxdev="nix develop"
alias nxrun="nix run"
alias nxflake="nix flake"
