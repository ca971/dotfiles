[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	line-numbers = true
	side-by-side = false
	hyperlinks = true
	hyperlinks-file-link-format = vscode://file/{path}:{line}
	syntax-theme = Catppuccin Mocha
	plus-style = "syntax #2a363b"
	minus-style = "syntax #3b2c34"
	plus-emph-style = "syntax #3a5540"
	minus-emph-style = "syntax #5b3040"
[merge]
	conflictstyle = zdiff3
[delta "merge"]
	conflictstyle = zdiff3
